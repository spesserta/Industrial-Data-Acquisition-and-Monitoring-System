<UserControl x:Class="Indus.Industrial.View.AlarmManange"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Indus.Industrial.ViewModel"
             xmlns:model="clr-namespace:Indus.Industrial.Model"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1200">
    <UserControl.Resources>
        <vm:AlarmManageModel x:Key="alarmVM"/>
    </UserControl.Resources>
    <Grid DataContext="{Binding Source={StaticResource alarmVM}}" Background="#2D2D2D">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Margin="10" CornerRadius="6" Background="DimGray" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="Orange" CornerRadius="6,6,0,0" Padding="10,8">
                    <TextBlock Text="设备列表" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                </Border>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding DeviceList}"
                         SelectedItem="{Binding SelectedDevice}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White"
                         FontSize="14"
                         Margin="0,5">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="model:DeviceModel">
                            <TextBlock Text="{Binding DeviceName}" Margin="8,6"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ========== 右侧：阈值管理 ========== -->
        <Grid Grid.Column="1" Margin="0,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <Border CornerRadius="6,6,0,0" Background="DimGray" Padding="14,10"
                    BorderBrush="DimGray" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="阈值配置" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedDevice.DeviceName, StringFormat='当前设备：{0}'}"
                               Foreground="Gray" FontSize="13" Margin="20,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 监控点位表格 -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding SelectedDevice.MonitorValueList}"
                      SelectedItem="{Binding SelectedMonitorValue}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Background="DimGray"
                      Foreground="Black"
                      BorderBrush="DimGray"
                      BorderThickness="1,0,1,1"
                      RowHeaderWidth="0"
                      HeadersVisibility="Column"
                      FontSize="13"
                      Margin="0">
                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Orange"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="DimGray"/>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="点位名称" Binding="{Binding ValueName}" Width="*"/>
                    <DataGridTextColumn Header="描述" Binding="{Binding ValueDesc}" Width="*"/>
                    <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="60"/>
                    <DataGridTextColumn Header="极低 ↓↓" Binding="{Binding LoLoAlarm}" Width="90"/>
                    <DataGridTextColumn Header="低 ↓" Binding="{Binding LowAlarm}" Width="90"/>
                    <DataGridTextColumn Header="高 ↑" Binding="{Binding HighAlarm}" Width="90"/>
                    <DataGridTextColumn Header="极高 ↑↑" Binding="{Binding HiHiAlarm}" Width="90"/>
                    <DataGridTextColumn Header="当前值" Binding="{Binding CurrentValue, StringFormat={}{0:F2}}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 编辑区域 -->
            <Border Grid.Row="2" CornerRadius="0,0,6,6" Background="Gray" Padding="14,12"
                    BorderBrush="Gray" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="选中点位：" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedMonitorValue.ValueName}" Foreground="White" FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="8,0,20,0"/>

                    <!-- 极低 -->
                    <TextBlock Grid.Column="2" Text="极低 ↓↓" Foreground="DarkBlue" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="3" Text="{Binding EditableLoLoAlarm}" Width="80" Margin="4,0,12,0"
                             Foreground="White" Background="#555" BorderBrush="#777" BorderThickness="1"
                             VerticalContentAlignment="Center" Padding="4,3"/>

                    <!-- 低 -->
                    <TextBlock Grid.Column="4" Text="低 ↓" Foreground="Blue" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="5" Text="{Binding EditableLowAlarm}" Width="80" Margin="4,0,12,0"
                             Foreground="White" Background="#555" BorderBrush="#777" BorderThickness="1"
                             VerticalContentAlignment="Center" Padding="4,3"/>

                    <!-- 高 -->
                    <TextBlock Grid.Column="2" Grid.Row="1" Text="高 ↑" Foreground="OrangeRed" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBox Grid.Column="3" Grid.Row="1" Text="{Binding EditableHighAlarm}" Width="80" Margin="4,8,12,0"
                             Foreground="White" Background="#555" BorderBrush="#777" BorderThickness="1"
                             VerticalContentAlignment="Center" Padding="4,3"/>

                    <!-- 极高 -->
                    <TextBlock Grid.Column="4" Grid.Row="1" Text="极高 ↑↑" Foreground="Red" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBox Grid.Column="5" Grid.Row="1" Text="{Binding EditableHiHiAlarm}" Width="80" Margin="4,8,12,0"
                             Foreground="White" Background="#555" BorderBrush="#777" BorderThickness="1"
                             VerticalContentAlignment="Center" Padding="4,3"/>

                    <!-- 保存按钮 -->
                    <Button Grid.Column="7" Grid.RowSpan="2" Content="保存修改"
                            Command="{Binding SaveCommand}"
                            Background="Orange" Foreground="White"
                            FontSize="14" FontWeight="Bold"
                            Padding="16,8"
                            BorderThickness="0"
                            VerticalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

